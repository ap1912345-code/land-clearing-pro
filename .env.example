# Copy to .env and fill in. .env is gitignored.
OPENAI_API_KEY=sk-...
# Override if a different image model name is needed (gpt-image-1, gpt-image-2, etc.)
OPENAI_IMAGE_MODEL=gpt-image-2
# Public site config used at build time (Vite reads VITE_* vars)
VITE_BUSINESS_NAME="Prentiss Services LLC"
VITE_BUSINESS_PHONE="(555) 123-4567"
VITE_BUSINESS_PHONE_TEL="+15551234567"
VITE_SERVICE_AREA="Central Massachusetts"
VITE_FB_PIXEL_ID=
VITE_GA4_ID=
# Web3Forms access key (https://web3forms.com — leads delivered to your verified email)
VITE_WEB3FORMS_KEY=
# ipify Geolocation API key (https://geo.ipify.org). Used by api/geo.ts at request time.
# Server-side only — do NOT prefix with VITE_; we don't want it shipped to the browser.
GEO_IPIFY_API_KEY=
